#: data/com.raggesilver.BlackBox.desktop.in:2
msgid "Black Box"
msgstr "ব্ল্যাক বক্স"

#: data/com.raggesilver.BlackBox.desktop.in:8
msgid "Terminal;terminal;shell;prompt;command;commandline;cmd;box;"
msgstr "টার্মিনাল;শেল;প্রম্পট;কমান্ড;কমান্ডলাইন;সি.এম.ডি;বক্স;"

#: data/com.raggesilver.BlackBox.gschema.xml:6
msgid "Window width"
msgstr "উইন্ডো প্রস্থ"

#: data/com.raggesilver.BlackBox.gschema.xml:10
msgid "Window height"
msgstr "উইন্ডো উচ্চতা"

#: data/com.raggesilver.BlackBox.gschema.xml:14
msgid "Whether or not to remember window size"
msgstr "উইন্ডো সাইজ মনে রাখবো কিনা"

#: data/com.raggesilver.BlackBox.gschema.xml:24
msgid "Font family and size"
msgstr "ফন্ট ফ্যামিলি এবং সাইজ"

#: data/com.raggesilver.BlackBox.gschema.xml:28
msgid "Whether the window should inherit terminal theme's colors"
msgstr "উইন্ডো কি টার্মিনাল থিমের রং ব্যবহার করবে"

#: data/com.raggesilver.BlackBox.gschema.xml:32
msgid "Terminal window background opacity"
msgstr "টার্মিনাল উইন্ডো ব্যাকগ্রাউন্ড অস্বচ্ছতা"

#: data/com.raggesilver.BlackBox.gschema.xml:36
msgid "Whether or not tabs should expand to fill tab bar"
msgstr "ট্যাবগুলো কি ট্যাব বারের সম্পূর্ণ জায়গা ব্যবহার করবে"

#: data/com.raggesilver.BlackBox.gschema.xml:40
msgid "Whether the headerbar should be shown or not"
msgstr "হেডারবার কি দেখাবো"

#: data/com.raggesilver.BlackBox.gschema.xml:44
msgid ""
"If enabled, the header bar will be colored differently for root and ssh "
"contexts"
msgstr ""
"সক্রিয় করা থাকলে root এবং ssh কনটেক্সট-এর ক্ষেত্রে হেডার বারের রঙ আলাদা হবে"

#: data/com.raggesilver.BlackBox.gschema.xml:48
msgid "Whether or not to display a menu button in the headerbar"
msgstr "হেডারবারে মেনু বাটন দেখানো হবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:52
msgid "Whether or not to reserve an area for dragging the header bar"
msgstr "হেডার বার ড্র্যাগ করার জন্য জায়গা রাখা হবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:56
msgid "Whether or not to show scrollbars"
msgstr "স্ক্রলবার দেখানো হবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:60
msgid "Whether overlay scrolling should be enabled"
msgstr "ওভারলে স্ক্রলিং সক্রিয় করা হবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:64
msgid "If enabled, terminals will scroll by pixels instead of rows"
msgstr ""
"সক্রিয় করা থাকলে টার্মিনাল সোজাসুজি সারির বদলে পিক্সেল অনুযায়ী স্ক্রল হবে"

#: data/com.raggesilver.BlackBox.gschema.xml:68
msgid "If enabled, terminals will render sixel escape sequences"
msgstr "সক্রিয় করা থাকলে টার্মিনাল sixel এস্কেপ সিকোয়েন্স রেন্ডার করবে"

#. 0 = Fixed size, 1 = Unlimited, 2 = Disabled
#: data/com.raggesilver.BlackBox.gschema.xml:73
#: src/gtk/preferences-window.ui:308
msgid "Scrollback mode"
msgstr "স্ক্রলব্যাক মোড"

#: data/com.raggesilver.BlackBox.gschema.xml:77
msgid "Number of lines stored in scrollback"
msgstr "স্ক্রলব্যাকে কতগুলো লাইন জমা রাখা হবে"

#: data/com.raggesilver.BlackBox.gschema.xml:81
msgid "If enabled, floating controls will be shown in headerless mode"
msgstr "সক্রিয় করা থাকলে হেডারলেস মোডে ফ্লোটিং কন্ট্রোলগুলো দেখানো হবে"

#: data/com.raggesilver.BlackBox.gschema.xml:85
msgid ""
"Hoverable area (in pixels) at the top of the window to trigger floating "
"controls"
msgstr ""
"ফ্লোটিং কন্ট্রোল সক্রিয় করার জন্য উইন্ডোর উপরের অংশে হোভার করার জায়গা (পিক্সেল হিসেবে)"

#: data/com.raggesilver.BlackBox.gschema.xml:89
msgid "Delay time before showing floating controls"
msgstr "ফ্লোটিং কন্ট্রোলগুলো দেখানোর আগে বিলম্বের সময়"

#: data/com.raggesilver.BlackBox.gschema.xml:93
msgid "The light color scheme for the terminal"
msgstr "টার্মিনালের জন্য হালকা রঙের স্কিম"

#: data/com.raggesilver.BlackBox.gschema.xml:97
msgid "The dark color scheme for the terminal"
msgstr "টার্মিনালের জন্য গাঢ় রঙের স্কিম"

#. 0 = Follow system, 1 = Light Style, 2 = Dark Style
#: data/com.raggesilver.BlackBox.gschema.xml:102
msgid "Style preference"
msgstr "স্টাইল পছন্দ"

#: data/com.raggesilver.BlackBox.gschema.xml:106
msgid "Show bold text in bright colors"
msgstr "বোল্ড টেক্সট উজ্জ্বল রঙে দেখানো হবে কিনা"

#: data/com.raggesilver.BlackBox.gschema.xml:110
msgid "Hide cursor while typing"
msgstr "টাইপ করার সময় কার্সর লুকিয়ে রাখা হবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:114
msgid "Amount of padding around terminal widgets (top, right, bottom, left)"
msgstr "টার্মিনাল উইজেটের চারপাশের প্যাডিংয়ের পরিমাণ (উপর, ডান, নিচে, বাম)"

#: data/com.raggesilver.BlackBox.gschema.xml:118
msgid "Terminal cell width"
msgstr "টার্মিনাল সেলের প্রস্থ"

#: data/com.raggesilver.BlackBox.gschema.xml:122
msgid "Terminal cell height"
msgstr "টার্মিনাল সেলের উচ্চতা"

#: data/com.raggesilver.BlackBox.gschema.xml:126
msgid "Terminal bell"
msgstr "টার্মিনাল বেল"

#: data/com.raggesilver.BlackBox.gschema.xml:130
msgid "Cursor shape"
msgstr "কার্সরের আকৃতি"

#: data/com.raggesilver.BlackBox.gschema.xml:134
msgid "Whether or not the cursor should blink"
msgstr "কার্সর ব্লিংক করবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:138
msgid "If enabled, ctrl+c and ctrl+v will work for copy/paste"
msgstr "সক্রিয় করা থাকলে কপি বা পেস্ট করার জন্য ctrl+c এবং ctrl+v কাজ করবে"

#: data/com.raggesilver.BlackBox.gschema.xml:142
msgid "Whether to spawn shell in login mode"
msgstr "লগইন মোডে শেল চালু করা হবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:146
msgid "Whether to use a custom command instead of the user's shell"
msgstr "ইউজারের শেলের পরিবর্তে কাস্টম কমান্ড ব্যবহার করা হবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:150
msgid "Custom command to use instead of the user's shell"
msgstr "ইউজারের শেলের পরিবর্তে যে কাস্টম কমান্ড ব্যবহার করা হবে"

#: data/com.raggesilver.BlackBox.gschema.xml:154
msgid ""
"Send a desktop notification when a process is completed on an unfocussed tab"
msgstr "আনফোকাসড ট্যাবে কোনো প্রসেস শেষ হলে ডেস্কটপ নোটিফিকেশন পাঠানো হবে কি না"

#. 0 = Previous terminal CWD, 1 = Home Directory, 2 = Custom
#: data/com.raggesilver.BlackBox.gschema.xml:159
msgid "Working directory mode"
msgstr "চলতি ডিরেক্টরি মোড"

#: data/com.raggesilver.BlackBox.gschema.xml:163
msgid "Custom working directory for new terminals"
msgstr "নতুন টার্মিনালের জন্য কাস্টম চলতি ডিরেক্টরি"

#: data/com.raggesilver.BlackBox.gschema.xml:171
#, fuzzy
msgid ""
"Whether clicking next on the last search result should return to the first"
msgstr ""
"সর্বশেষ সার্চ রেজাল্টে থাকা অবস্থায় 'পরবর্তী' (Next) ক্লিক করলে পুনরায় প্রথম রেজাল্টে ফিরে "
"যাবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:175
msgid "Whether search should be case sensitive"
msgstr "সার্চের ক্ষেত্রে ছোট হাতের বা বড় হাতের অক্ষর বিবেচনা করা হবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:179
msgid "Whether search should only match entire words"
msgstr "সার্চের ফলাফল শুধুমাত্র সম্পূর্ণ শব্দের সাথে মিলবে কি না"

#: data/com.raggesilver.BlackBox.gschema.xml:183
msgid "Whether search should be performed using regular expressions"
msgstr ""
"রেগুলার এক্সপ্রেশন (Regular Expressions) ব্যবহার করে সার্চ করা হবে কি না"

#: src/gtk/shortcut-dialog.ui:6
msgid "Edit Shortcut"
msgstr "শর্টকাট পরিবর্তন করুন"

#: src/gtk/shortcut-dialog.ui:17 src/utils/Dialogs.vala:36
#: src/utils/Dialogs.vala:38 src/widgets/PreferencesWindow.vala:606
#: src/widgets/ShortcutEditor.vala:246 src/widgets/Window.vala:632
msgid "Cancel"
msgstr "বাতিল করুন"

#: src/gtk/shortcut-dialog.ui:24
msgid "Apply"
msgstr "প্রয়োগ করুন"

#: src/gtk/shortcut-dialog.ui:65
msgid "This shortcut is already in use"
msgstr "এই শর্টকাটটি ইতিমধ্যে ব্যবহৃত হচ্ছে"

#: src/gtk/shortcut-dialog.ui:78
msgid "Press Escape to cancel or Backspace to disable shortcut"
msgstr "বাতিল করতে Escape চাপুন অথবা শর্টকাটটি নিষ্ক্রিয় করতে Backspace চাপুন"

#: src/gtk/shortcut-editor.ui:6
msgid "Keyboard"
msgstr "কীবোর্ড"

#: src/gtk/shortcut-editor.ui:10
msgid "Shortcuts"
msgstr "শর্টকাট"

#: src/gtk/shortcut-editor.ui:29
msgid "Reset All Shortcuts"
msgstr "সকল শর্টকাট রিসেট করুন"

#: src/gtk/shortcut-editor.ui:30
msgid ""
"This will reset all shortcuts to their default keybindings and overwrite "
"your config file."
msgstr ""
"এর ফলে সকল শর্টকাট ডিফল্ট কী-বাইন্ডিংয়ে রিসেট হবে এবং আপনার কনফিগ ফাইলটি ওভাররাইট হয়ে "
"যাবে।"

#: src/gtk/shortcut-editor.ui:34
msgid "Reset All"
msgstr "সব রিসেট করুন"

#: src/gtk/search-toolbar.ui:20
msgid "Find"
msgstr "খুঁজুন"

#: src/gtk/search-toolbar.ui:41
msgid "Previous result"
msgstr "পূর্ববর্তী ফলাফল"

#: src/gtk/search-toolbar.ui:47
msgid "Next result"
msgstr "পরবর্তী ফলাফল"

#: src/gtk/search-toolbar.ui:89
msgid "Search wraps around"
msgstr "সার্চ পুনরায় শুরু থেকে শুরু হবে"

#: src/gtk/search-toolbar.ui:94
msgid "Match is case sensitive"
msgstr "ছোট-বড় হাতের অক্ষর মিলিয়ে দেখা হবে"

#: src/gtk/search-toolbar.ui:99
msgid "Match entire words only"
msgstr "শুধুমাত্র সম্পূর্ণ শব্দের সাথে মিলানো হবে"

#: src/gtk/search-toolbar.ui:104
msgid "Match using regular expression"
msgstr "রেগুলার এক্সপ্রেশন ব্যবহার করে মিলানো হবে"

#: src/gtk/preferences-window.ui:11
msgid "General"
msgstr "সাধারণ"

#: src/gtk/preferences-window.ui:15
msgid "Window"
msgstr "উইন্ডো"

#: src/gtk/preferences-window.ui:18
msgid "Remember Window Size"
msgstr "উইন্ডোর আকার মনে রাখা হবে"

#: src/gtk/preferences-window.ui:23
msgid "Theme settings have been moved to Terminal > Appearance."
msgstr "থিম সেটিংস Terminal > Appearance-এ সরিয়ে নেওয়া হয়েছে।"

#: src/gtk/preferences-window.ui:36
msgid "Tabs"
msgstr "ট্যাব"

#: src/gtk/preferences-window.ui:39
msgid "Expand Tabs"
msgstr "ট্যাব বিস্তৃত করা হবে"

#: src/gtk/preferences-window.ui:46
msgid "Header Bar"
msgstr "হেডার বার"

#: src/gtk/preferences-window.ui:49
msgid "Show Header Bar"
msgstr "হেডার বার প্রদর্শন করা হবে"

#: src/gtk/preferences-window.ui:54
msgid "Context Aware"
msgstr "কনটেক্সট-নির্ভর"

#: src/gtk/preferences-window.ui:55
msgid ""
"If enabled, the header bar will be colored differently when the active tab "
"is running ssh or sudo."
msgstr ""
"সক্রিয় করা থাকলে, সক্রিয় ট্যাবে ssh অথবা sudo চললে হেডার বারের রঙ পরিবর্তন হবে।"

#: src/gtk/preferences-window.ui:60
msgid "Show Menu Button"
msgstr "মেনু বাটন প্রদর্শন করুন"

#: src/gtk/preferences-window.ui:65
msgid "Drag Area"
msgstr "উইন্ডো সরানোর জায়গা"

#: src/gtk/preferences-window.ui:66
msgid "Enable to reserve some space on the left side to drag the window."
msgstr ""
"উইন্ডো সরানোর সুবিধার্থে বাম পাশে কিছুটা জায়গা খালি রাখতে এটি সক্রিয় করুন।"

#: src/gtk/preferences-window.ui:71
msgid "Floating Controls"
msgstr "ভাসমান নিয়ন্ত্রণসমূহ"

#: src/gtk/preferences-window.ui:74
msgid "Show Floating Controls"
msgstr "ভাসমান নিয়ন্ত্রণসমূহ প্রদর্শন করুন"

#: src/gtk/preferences-window.ui:75
msgid "Show floating controls when header bar is hidden."
msgstr "হেডার বার লুকানো থাকলে ভাসমান নিয়ন্ত্রণসমূহ প্রদর্শন করুন।"

#: src/gtk/preferences-window.ui:81
msgid "Floating Controls Hover Area"
msgstr "ভাসমান নিয়ন্ত্রণ হোভার জায়গা"

#: src/gtk/preferences-window.ui:82
msgid ""
"Hoverable area (in pixels) at the top of the window to trigger floating "
"controls."
msgstr ""
"ভাসমান নিয়ন্ত্রণসমূহ সক্রিয় করতে উইন্ডোর উপরের হোভারযোগ্য এলাকা (পিক্সেল হিসেবে)।"

#: src/gtk/preferences-window.ui:89
msgid "Delay Before Show Floating Controls"
msgstr "ভাসমান নিয়ন্ত্রণ দেখানোর আগের বিলম্ব"

#: src/gtk/preferences-window.ui:90
msgid "Delay time (ms) before show floating controls."
msgstr "ভাসমান নিয়ন্ত্রণ দেখানোর আগের বিলম্বের সময় (মিলিসেকেন্ডে)।"

#: src/gtk/preferences-window.ui:103 src/gtk/preferences-window.ui:157
msgid "Terminal"
msgstr "টার্মিনাল"

#: src/gtk/preferences-window.ui:108
msgid "Text"
msgstr "টেক্সট"

#: src/gtk/preferences-window.ui:112
msgid "Font"
msgstr "ফন্ট"

#: src/gtk/preferences-window.ui:124
msgid "Cell Spacing"
msgstr "সেলের মধ্যবর্তী দূরত্ব"

#: src/gtk/preferences-window.ui:127
msgid "Width"
msgstr "প্রস্থ"

#: src/gtk/preferences-window.ui:134
msgid "Height"
msgstr "উচ্চতা"

#: src/gtk/preferences-window.ui:143
msgid "Bright Bold Text"
msgstr "উজ্জ্বল বোল্ড টেক্সট"

#: src/gtk/preferences-window.ui:144
msgid "Use bright colors for bold text."
msgstr "বোল্ড টেক্সটের জন্য হালকা রঙ ব্যবহার করুন।"

#: src/gtk/preferences-window.ui:149
msgid "Easy Copy &amp; Paste"
msgstr "সহজ কপি ও পেস্ট"

#: src/gtk/preferences-window.ui:150
msgid "Use ctrl+c/ctrl+v for copy/paste."
msgstr "কপি/পেস্টের জন্য ctrl+c/ctrl+v ব্যবহার করুন।"

#: src/gtk/preferences-window.ui:161
msgid "Audible Bell"
msgstr "শ্রবণযোগ্য বেল"

#: src/gtk/preferences-window.ui:162
msgid "If enabled, terminals might use an audible bell to indicate events."
msgstr ""
"সক্রিয় করা থাকলে, বিভিন্ন ঘটনার ক্ষেত্রে টার্মিনাল শব্দ সংকেত ব্যবহার করতে পারে।"

